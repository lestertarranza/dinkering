# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only. NEVER expose to the browser.
# Used for public portal reads (by token) and admin import/ledger writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL used when generating shareable player/group links
NEXT_PUBLIC_APP_URL=http://localhost:3000
